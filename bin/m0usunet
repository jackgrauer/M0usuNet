#!/bin/sh
# If passing args (like "ingest"), run directly without tmux
if [ $# -gt 0 ]; then
    exec ~/m0usunet/.venv/bin/python3 -m m0usunet "$@"
fi

# For the TUI: attach to existing tmux session or create one
SESSION="m0usunet"
if tmux has-session -t "$SESSION" 2>/dev/null; then
    exec tmux attach-session -t "$SESSION"
else
    exec tmux new-session -s "$SESSION" ~/m0usunet/.venv/bin/python3 -m m0usunet
fi
