/* m0usunet theme — v4 */

Screen {
    background: #0a0a0a;
    color: #e0e0e0;
}

/* ── Header bar ── */

HeaderBar {
    height: 3;
    dock: top;
    background: #0d0d0d;
    border-bottom: heavy #00d4ff;
    padding: 0 1;
    color: #e0e0e0;
}

HeaderBar Horizontal {
    height: 1;
    width: 100%;
}

HeaderBar #app-title {
    width: auto;
    color: #00d4ff;
    text-style: bold;
}

HeaderBar #title-spacer {
    width: 1;
}

HeaderBar .header-spacer {
    width: 1fr;
}

HeaderBar #clock {
    width: auto;
}

.tab-btn {
    width: auto;
    height: 1;
    background: #1a1a1a;
    color: #555555;
    margin: 0 1 0 0;
}

.tab-btn:hover {
    color: #e0e0e0;
    background: #2a2a2a;
}

.tab-btn.--active {
    text-style: bold;
}

#tab-messages.--active {
    background: #1a3a1a;
    color: #50fa7b;
}

#tab-editor.--active {
    background: #1a1a2a;
    color: #00d4ff;
}

HeaderBar #unread-count {
    width: auto;
    margin: 0 1 0 0;
}

HeaderBar #ingest-status {
    width: auto;
    margin: 0 1 0 0;
}

HeaderBar #mesh-status {
    color: #e0e0e0;
    width: auto;
    margin: 0 1 0 0;
}

/* ── Left panel: conversation list ── */

ConversationList {
    height: 10;
    border-bottom: heavy #00d4ff;
    padding: 0;
    background: #0a0a0a;
}

ConversationItem {
    height: 2;
    padding: 0 1;
    background: #0a0a0a;
    color: #e0e0e0;
    border-left: thick #0a0a0a;
}

ConversationItem.--highlight {
    background: #152030;
    border-left: thick #00d4ff;
}

.conv-name {
    color: #e0e0e0;
    text-style: bold;
}

.--highlight .conv-name {
    color: #00d4ff;
}

.conv-preview {
    color: #555555;
}

/* ── Right panel: chat TextArea ── */

ChatView {
    padding: 0;
    background: #0a0a0a;
}

#chat-area {
    background: #0a0a0a;
    color: #e0e0e0;
    border: none;
    width: 100%;
    height: 1fr;
}

#chat-area:focus {
    border: none;
}

/* ── Bottom: compose box ── */

#reply-btn {
    width: auto;
    height: 1;
    background: #1a3a1a;
    color: #50fa7b;
    text-style: bold;
}

#reply-btn:hover {
    color: #0a0a0a;
    background: #50fa7b;
}

#attach-btn {
    width: auto;
    height: 1;
    background: #2a1a00;
    color: #ff8c00;
    text-style: bold;
}

#attach-btn:hover {
    color: #0a0a0a;
    background: #ff8c00;
}

#attach-indicator {
    height: 1;
    color: #ff8c00;
}

ComposeBox {
    height: auto;
    max-height: 3;
    dock: bottom;
    padding: 0;
    background: #0d0d0d;
    border-top: heavy #1a5c7a;
}

ComposeBox Horizontal {
    height: 1;
    width: 100%;
}

#compose-prompt {
    color: #00d4ff;
    text-style: bold;
    width: 3;
}

ComposeBox Input {
    background: #111111;
    color: #e0e0e0;
    border: none;
    width: 1fr;
    padding: 0;
}

ComposeBox Input:focus {
    border: none;
    color: #e0e0e0;
}

ComposeBox Input.--over-limit {
    color: #f75341;
}

ComposeBox Input.--over-limit:focus {
    color: #f75341;
}

ComposeBox Input.-placeholder {
    color: #555555;
}

#relay-status {
    height: auto;
    max-height: 1;
}

ComposeBox .error {
    color: #f75341;
}

ComposeBox .success {
    color: #50fa7b;
}

/* ── Empty state ── */

.empty-state {
    color: #555555;
    text-align: center;
    padding-top: 3;
}
